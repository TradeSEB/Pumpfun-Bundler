{
  "name": "pumpfun-jito-bundler-bot",
  "version": "1.0.0",
  "description": "Pump.fun launcher and bundled buyer/seller bot using Solana + Jito bundles",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "launch-and-bundle": "tsx src/index.ts launch-and-bundle",
    "sell-all": "tsx src/index.ts sell-all",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "solana",
    "pumpfun",
    "jito",
    "bundler",
    "trading-bot"
  ],
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.7.9",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
